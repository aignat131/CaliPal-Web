rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isSuperAdmin() {
      return isAuth() && request.auth.token.email == 'aignat131@gmail.com';
    }
    function getCommunityMember(communityId) {
      return get(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid));
    }
    function isCommunityMember(communityId) {
      return isAuth() && exists(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid));
    }
    function getMemberRole(communityId) {
      return getCommunityMember(communityId).data.role;
    }
    function isCommunityAdmin(communityId) {
      return isCommunityMember(communityId) && getMemberRole(communityId) == 'ADMIN';
    }
    function isCommunityStaff(communityId) {
      return isCommunityMember(communityId) &&
        getMemberRole(communityId) in ['ADMIN', 'MODERATOR', 'TRAINER'];
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isSuperAdmin();

      match /workouts/{workoutId} {
        allow read: if isAuth();
        allow write: if isOwner(uid);
      }
      match /skills/{skillId} {
        allow read: if isAuth();
        allow write: if isOwner(uid);
      }
      match /challenge_progress/{challengeId} {
        allow read, write: if isOwner(uid);
      }
      match /community_challenge_progress/{challengeId} {
        allow read, write: if isOwner(uid);
      }
      // Friends subcollection — any auth user can read; owner or the friend themselves can write
      match /friends/{friendId} {
        allow read: if isAuth();
        allow create: if isOwner(uid) || (isAuth() && request.auth.uid == friendId);
        allow delete: if isOwner(uid) || (isAuth() && request.auth.uid == friendId);
      }
    }

    // ── Coin tasks (one-time award guards) ────────────────────────────────────
    match /coin_tasks/{taskId} {
      // Documents have a `uid` field — filter queries by uid so rules can be validated
      allow read: if isAuth() && resource.data.uid == request.auth.uid;
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── FCM tokens ────────────────────────────────────────────────────────────
    match /fcm_tokens/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── Communities ───────────────────────────────────────────────────────────
    match /communities/{communityId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isCommunityAdmin(communityId) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      match /members/{uid} {
        allow read: if true;
        allow create: if isOwner(uid);
        allow update: if isOwner(uid) || isCommunityAdmin(communityId) || isSuperAdmin();
        allow delete: if isOwner(uid) || isCommunityAdmin(communityId) || isSuperAdmin();
      }

      match /posts/{postId} {
        allow read: if true;
        allow create: if isCommunityMember(communityId);
        allow update: if isAuth() && (
          request.auth.uid == resource.data.authorId ||
          isCommunityStaff(communityId) ||
          isSuperAdmin()
        );
        allow delete: if isAuth() && (
          request.auth.uid == resource.data.authorId ||
          isCommunityStaff(communityId) ||
          isSuperAdmin()
        );

        match /comments/{commentId} {
          allow read: if true;
          allow create: if isCommunityMember(communityId);
          allow update, delete: if isAuth() && (
            request.auth.uid == resource.data.authorId ||
            isCommunityStaff(communityId) ||
            isSuperAdmin()
          );
        }

        match /likes/{uid} {
          allow read: if true;
          allow write: if isOwner(uid);
        }
      }

      match /trainings/{trainingId} {
        allow read: if isCommunityMember(communityId);
        allow create, delete: if isCommunityStaff(communityId) || isSuperAdmin();
        // Members can update only their own RSVP field; staff can update anything
        allow update: if isCommunityMember(communityId) || isSuperAdmin();
      }

      match /challenges/{challengeId} {
        allow read: if isAuth();
        allow create: if isSuperAdmin() || isCommunityStaff(communityId);
        allow update, delete: if isSuperAdmin() || isCommunityAdmin(communityId);
      }
    }

    // ── Direct messages ───────────────────────────────────────────────────────
    match /conversations/{conversationId} {
      function isParticipant() {
        return isAuth() && resource != null && request.auth.uid in resource.data.participantIds;
      }
      // resource is null when the doc doesn't exist — guard before accessing .data
      allow read: if resource == null || isParticipant();
      allow create: if isAuth() && request.auth.uid in request.resource.data.participantIds;
      allow update: if isParticipant();

      match /messages/{messageId} {
        // get() returns null if conversation doesn't exist — guard with helper
        function convParticipants() {
          let conv = get(/databases/$(database)/documents/conversations/$(conversationId));
          return conv == null ? [] : conv.data.participantIds;
        }
        allow read: if isAuth() && request.auth.uid in convParticipants();
        allow create: if isAuth() &&
          request.auth.uid in convParticipants() &&
          request.auth.uid == request.resource.data.senderId;
        allow delete: if isAuth() && resource.data.senderId == request.auth.uid;
      }
    }

    // ── Friend requests ───────────────────────────────────────────────────────
    match /friend_requests/{requestId} {
      // resource is null when the doc doesn't exist — must guard before accessing .data
      allow read: if isAuth() && (
        resource == null ||
        request.auth.uid == resource.data.fromUid ||
        request.auth.uid == resource.data.toUid
      );
      allow create: if isAuth() && request.auth.uid == request.resource.data.fromUid;
      // Both sender (re-send) and recipient (accept/decline) may update
      allow update: if isAuth() && (
        request.auth.uid == resource.data.toUid ||
        request.auth.uid == resource.data.fromUid
      );
      allow delete: if isAuth() && (
        request.auth.uid == resource.data.fromUid ||
        request.auth.uid == resource.data.toUid
      );
    }

    // ── Parks ─────────────────────────────────────────────────────────────────
    match /parks/{parkId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ── Live locations ────────────────────────────────────────────────────────
    match /live_locations/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid);
    }

    // ── Park presence ─────────────────────────────────────────────────────────
    match /park_presence/{communityId}/active_members/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid);
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{uid} {
      match /items/{itemId} {
        allow read, delete: if isOwner(uid);
        allow create: if isAuth();
        allow update: if isOwner(uid);
      }
    }

    // ── Weekly challenges ─────────────────────────────────────────────────────
    match /weekly_challenges/{challengeId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
  }
}
